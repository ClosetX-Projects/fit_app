
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Verifica se existe o vínculo na coleção de relacionamento
    function isProfessorOfStudent(studentId) {
      return isSignedIn() && exists(/databases/$(database)/documents/professors/$(request.auth.uid)/students/$(studentId));
    }

    function canAccessStudentData(studentId) {
      // 1. O dono da conta sempre tem acesso
      if (isOwner(studentId)) return true;
      
      // 2. O professor vinculado tem acesso
      if (isProfessorOfStudent(studentId)) return true;

      // 3. Verificação por E-mail (Crucial para Migração/Reivindicação de perfil)
      // Permite que o aluno acesse dados criados pelo professor antes do vínculo de UID ser estabelecido
      let userDocPath = /databases/$(database)/documents/users/$(studentId);
      if (exists(userDocPath)) {
        let userDoc = get(userDocPath).data;
        // Permite se o e-mail coincidir ou se o usuário foi quem criou o registro
        return (isSignedIn() && request.auth.token.email != null && userDoc.email.lower() == request.auth.token.email.lower()) ||
               (userDoc.createdBy == request.auth.uid);
      }
      
      return false;
    }

    // Perfis de usuários e subcoleções
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      // Adicionado 'delete' para permitir que o aluno limpe o perfil temporário após migrar dados
      allow update, delete: if canAccessStudentData(userId);

      // Regra genérica para todas as subcoleções (physicalAssessments, notifications, workoutHistory_flat, etc.)
      match /{allSubcollections=**} {
        allow read, write: if canAccessStudentData(userId);
      }
    }

    // ACL Professor-Aluno: Armazena o vínculo direto
    match /professors/{professorId}/students/{studentId} {
      allow read: if isOwner(professorId);
      allow write: if isOwner(professorId) || (isSignedIn() && request.auth.uid == studentId);
    }

    // Regras para Tokens de Autenticação (Acesso Público para validação de login)
    match /auth_codes/{email} {
      allow read, write: if true; 
    }

    // Atalhos para consultas em nível de raiz ou coleções específicas se necessário
    match /{path=**}/workoutSessions/{sessionId} {
      allow read: if isSignedIn() && (
        (request.auth.uid == resource.data.userId) || 
        isProfessorOfStudent(resource.data.userId)
      );
    }

    match /{path=**}/exercises/{exerciseId} {
      allow read: if isSignedIn() && (
        (request.auth.uid == resource.data.userId) || 
        isProfessorOfStudent(resource.data.userId)
      );
    }
  }
}
