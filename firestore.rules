
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isProfessorOfStudent(studentId) {
      return isSignedIn() && exists(/databases/$(database)/documents/professors/$(request.auth.uid)/students/$(studentId));
    }

    // Perfis de usuários e subcoleções diretas
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);

      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId) || isProfessorOfStudent(userId);
      }
    }

    // ACL Professor-Aluno
    match /professors/{professorId}/students/{studentId} {
      allow read, write: if isOwner(professorId);
    }

    // Regras para Tokens de Autenticação (Apenas sistema pode criar/deletar em teoria, mas para protótipo permitimos leitura se souber o código)
    match /auth_codes/{email} {
      allow read, write: if true; // Em produção isso seria restrito a Server Actions via Admin SDK
    }

    match /{path=**}/workoutSessions/{sessionId} {
      allow read: if isSignedIn() && (
        (request.auth.uid == resource.data.userId) || 
        exists(/databases/$(database)/documents/professors/$(request.auth.uid)/students/$(resource.data.userId))
      );
    }

    match /{path=**}/exercises/{exerciseId} {
      allow read: if isSignedIn() && (
        (request.auth.uid == resource.data.userId) || 
        exists(/databases/$(database)/documents/professors/$(request.auth.uid)/students/$(resource.data.userId))
      );
    }
  }
}
