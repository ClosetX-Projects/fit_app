rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isProfessorOfStudent(studentId) {
      return isSignedIn() && exists(/databases/$(database)/documents/professors/$(request.auth.uid)/students/$(studentId));
    }

    // Perfis de usuários e subcoleções diretas
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);

      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId) || isProfessorOfStudent(userId);
      }
    }

    // ACL Professor-Aluno
    match /professors/{professorId}/students/{studentId} {
      allow read, write: if isOwner(professorId);
    }

    // Regras para Collection Group Queries (Essencial para Dashboard e Análise)
    
    match /{path=**}/workoutSessions/{sessionId} {
      // Permite leitura se o usuário for o dono ou professor vinculado
      // Filtramos na query por userId para garantir que resource.data.userId seja validado
      allow read: if isSignedIn() && (
        (request.auth.uid == resource.data.userId) || 
        exists(/databases/$(database)/documents/professors/$(request.auth.uid)/students/$(resource.data.userId))
      );
    }

    match /{path=**}/exercises/{exerciseId} {
      allow read: if isSignedIn() && (
        (request.auth.uid == resource.data.userId) || 
        exists(/databases/$(database)/documents/professors/$(request.auth.uid)/students/$(resource.data.userId))
      );
    }
  }
}
