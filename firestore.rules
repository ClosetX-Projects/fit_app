
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------------------------------------------------
    // Helper Functions
    // --------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isProfessorOfStudent(studentId) {
      // Verifica se existe o vínculo na coleção de relacionamento
      return isSignedIn() && exists(/databases/$(database)/documents/professors/$(request.auth.uid)/students/$(studentId));
    }

    // --------------------------------------------------------------------------
    // Collection Group Rules: Essencial para Gráficos e Histórico
    // --------------------------------------------------------------------------
    
    match /{path=**}/workoutSessions/{sessionId} {
      allow read: if isSignedIn() && (
        (resource.data.userId == request.auth.uid) || 
        isProfessorOfStudent(resource.data.userId)
      );
    }

    match /{path=**}/exercises/{exerciseId} {
      allow read: if isSignedIn() && (
        (resource.data.userId == request.auth.uid) || 
        isProfessorOfStudent(resource.data.userId)
      );
    }

    // --------------------------------------------------------------------------
    // Collection Rules
    // --------------------------------------------------------------------------

    match /users/{userId} {
      allow get: if isSignedIn();
      allow create, update, delete: if isOwner(userId);

      match /physicalAssessments/{assessmentId} {
        allow read: if isOwner(userId) || isProfessorOfStudent(userId);
        allow write: if isOwner(userId);
        
        match /{subColl=**} {
          allow read: if isOwner(userId) || isProfessorOfStudent(userId);
          allow write: if isOwner(userId);
        }
      }
      
      match /trainingPrograms/{programId} {
        allow read: if isOwner(userId) || isProfessorOfStudent(userId);
        allow create, update, delete: if isProfessorOfStudent(userId);

        match /{subColl=**} {
          allow read: if isOwner(userId) || isProfessorOfStudent(userId);
          allow write: if isOwner(userId) || isProfessorOfStudent(userId);
        }
      }
    }

    match /professors/{professorId}/students/{studentId} {
      allow read, write: if isOwner(professorId);
    }
  }
}
