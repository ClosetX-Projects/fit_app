rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isProfessorOfStudent(studentId) {
      return isSignedIn() && exists(/databases/$(database)/documents/professors/$(request.auth.uid)/students/$(studentId));
    }

    // Regras para perfis de usuários e suas subcoleções
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);

      // Permite acesso recursivo a todas as subcoleções de um usuário
      match /{allSubcollections=**} {
        allow read: if isOwner(userId) || isProfessorOfStudent(userId);
        allow write: if isOwner(userId) || isProfessorOfStudent(userId);
      }
    }

    // Relacionamento Professor-Aluno (ACL)
    match /professors/{professorId}/students/{studentId} {
      allow read, write: if isOwner(professorId);
    }

    // Regras para Collection Group Queries
    // Estas regras são necessárias para consultas que buscam em múltiplas subcoleções com o mesmo nome
    
    match /{path=**}/workoutSessions/{sessionId} {
      // Permite leitura se o usuário for o dono da sessão ou o professor do dono
      allow read: if isSignedIn() && (
        (request.auth.uid == resource.data.userId) || 
        exists(/databases/$(database)/documents/professors/$(request.auth.uid)/students/$(resource.data.userId))
      );
    }

    match /{path=**}/exercises/{exerciseId} {
      // Permite leitura se o usuário for o dono do exercício ou o professor do dono
      allow read: if isSignedIn() && (
        (request.auth.uid == resource.data.userId) || 
        exists(/databases/$(database)/documents/professors/$(request.auth.uid)/students/$(resource.data.userId))
      );
    }
  }
}