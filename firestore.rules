rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isProfessorOfStudent(studentId) {
      return isSignedIn() && exists(/databases/$(database)/documents/professors/$(request.auth.uid)/students/$(studentId));
    }

    // Regras para perfis de usuários
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);

      match /physicalAssessments/{assessmentId} {
        allow read: if isOwner(userId) || isProfessorOfStudent(userId);
        allow write: if isOwner(userId);
        
        match /{subColl=**} {
          allow read: if isOwner(userId) || isProfessorOfStudent(userId);
          allow write: if isOwner(userId);
        }
      }
      
      match /trainingPrograms/{programId} {
        allow read: if isOwner(userId) || isProfessorOfStudent(userId);
        allow write: if isOwner(userId) || isProfessorOfStudent(userId);

        match /{subColl=**} {
          allow read: if isOwner(userId) || isProfessorOfStudent(userId);
          allow write: if isOwner(userId) || isProfessorOfStudent(userId);
        }
      }
    }

    // Relacionamento Professor-Aluno
    match /professors/{professorId}/students/{studentId} {
      allow read, write: if isOwner(professorId);
    }

    // Consultas de Collection Group (Sessões e Exercícios)
    match /{path=**}/workoutSessions/{sessionId} {
      allow read: if isSignedIn() && (
        (resource.data.userId == request.auth.uid) || 
        isProfessorOfStudent(resource.data.userId)
      );
    }

    match /{path=**}/exercises/{exerciseId} {
      allow read: if isSignedIn() && (
        (resource.data.userId == request.auth.uid) || 
        isProfessorOfStudent(resource.data.userId)
      );
    }
  }
}
