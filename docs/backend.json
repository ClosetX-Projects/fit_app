
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Perfil do usuário incluindo sinalizadores de saúde.",
      "properties": {
        "id": { "type": "string" },
        "userType": { "type": "string", "enum": ["student", "professor"] },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoUrl": { "type": "string" },
        "age": { "type": "number" },
        "gender": { "type": "string", "enum": ["male", "female", "other"] },
        "isHypertensive": { "type": "boolean" },
        "isDiabetic": { "type": "boolean" },
        "whatsapp": { "type": "string" },
        "restrictions": { "type": "string" },
        "anamnesis": { "type": "string" },
        "goals": { "type": "string" }
      }
    },
    "PhysicalAssessment": {
      "title": "PhysicalAssessment",
      "type": "object",
      "description": "Avaliação completa incluindo Bioimpedância, PA e Testes Físicos.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "weight": { "type": "number" },
        "height": { "type": "number" },
        "bloodPressure": {
          "type": "object",
          "properties": {
            "systolic": { "type": "number" },
            "diastolic": { "type": "number" }
          }
        },
        "bioimpedance": {
          "type": "object",
          "properties": {
            "bmr": { "type": "number" },
            "hydration": { "type": "number" },
            "bodyFatPercentage": { "type": "number" }
          }
        },
        "circumferences": { "type": "object" },
        "skinfolds": { "type": "object" },
        "physicalTests": { "type": "object" },
        "calculatedResults": { "type": "object" }
      }
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "Perfil" },
    "/users/{userId}/physicalAssessments/{id}": { "schema": "PhysicalAssessment", "description": "Avaliações" },
    "/users/{userId}/notifications/{id}": { "schema": "Notification", "description": "Notificações" },
    "/users/{userId}/workoutHistory_flat/{id}": { "schema": "object", "description": "Histórico de Treinos com Dados Vitais" }
  }
}
