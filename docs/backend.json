{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user (either student or professor) in the FitAssist application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the user."
        },
        "userType": {
          "type": "string",
          "description": "The type of user: 'student' or 'professor'."
        },
        "name": {
          "type": "string",
          "description": "The user's full name."
        },
        "age": {
          "type": "number",
          "description": "The user's age in years."
        },
        "gender": {
          "type": "string",
          "description": "The user's gender."
        },
        "email": {
          "type": "string",
          "description": "The user's email address.",
          "format": "email"
        },
        "whatsapp": {
          "type": "string",
          "description": "The user's WhatsApp number."
        }
      },
      "required": [
        "id",
        "userType",
        "name",
        "age",
        "gender",
        "email"
      ]
    },
    "PhysicalAssessment": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "PhysicalAssessment",
      "type": "object",
      "description": "Represents a physical assessment record for a student.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the physical assessment."
        },
        "userId": {
          "type": "string",
          "description": "Reference to User. (Relationship: User 1:N PhysicalAssessment)"
        },
        "date": {
          "type": "string",
          "description": "The date of the physical assessment.",
          "format": "date-time"
        },
        "weight": {
          "type": "number",
          "description": "The user's weight in kilograms."
        },
        "height": {
          "type": "number",
          "description": "The user's height in centimeters."
        }
      },
      "required": [
        "id",
        "userId",
        "date",
        "weight",
        "height"
      ]
    },
    "CircumferenceMeasurement": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "CircumferenceMeasurement",
      "type": "object",
      "description": "Represents a circumference measurement taken during a physical assessment.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the circumference measurement."
        },
        "physicalAssessmentId": {
          "type": "string",
          "description": "Reference to PhysicalAssessment. (Relationship: PhysicalAssessment 1:N CircumferenceMeasurement)"
        },
        "peitoral": {
          "type": "number",
          "description": "Peitoral circumference measurement."
        },
        "cintura": {
          "type": "number",
          "description": "Cintura (waist) circumference measurement."
        },
        "abdomen": {
          "type": "number",
          "description": "Abdomen circumference measurement."
        },
        "quadril": {
          "type": "number",
          "description": "Quadril (hip) circumference measurement."
        },
        "coxa": {
          "type": "number",
          "description": "Coxa (thigh) circumference measurement."
        },
        "perna": {
          "type": "number",
          "description": "Perna (calf) circumference measurement."
        },
        "braco": {
          "type": "number",
          "description": "Braço (arm) circumference measurement."
        },
        "antebraco": {
          "type": "number",
          "description": "Antebraço (forearm) circumference measurement."
        }
      },
      "required": [
        "id",
        "physicalAssessmentId"
      ]
    },
    "Exercise": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Exercise",
      "type": "object",
      "description": "Represents a specific exercise within a workout session or prescribed in a program.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the exercise."
        },
        "name": {
          "type": "string",
          "description": "The name of the exercise."
        },
        "sets": {
          "type": "number",
          "description": "Number of sets for the exercise."
        },
        "reps": {
          "type": "string",
          "description": "Number of repetitions or time."
        },
        "weight": {
          "type": "number",
          "description": "Weight used for the exercise in kilograms."
        },
        "pseExercise": {
          "type": "number",
          "description": "PSE (Perceived exertion) for the Exercise."
        }
      },
      "required": [
        "id",
        "name"
      ]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": {
            "$ref": "#/backend/entities/User"
          },
          "description": "Stores user profile data.",
          "params": [
            {
              "name": "userId",
              "description": "The Firebase Auth UID of the user."
            }
          ]
        }
      },
      {
        "path": "/users/{userId}/trainingPrograms/{programId}/prescribedExercises/{exerciseId}",
        "definition": {
          "entityName": "Exercise",
          "schema": {
            "$ref": "#/backend/entities/Exercise"
          },
          "description": "Exercises prescribed by the professor for a specific program.",
          "params": [
            { "name": "userId" },
            { "name": "programId" },
            { "name": "exerciseId" }
          ]
        }
      }
    ]
  }
}