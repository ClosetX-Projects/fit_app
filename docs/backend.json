
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user (either student or professor) in the FitAssist application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the user."
        },
        "userType": {
          "type": "string",
          "description": "The type of user: 'student' or 'professor'."
        },
        "name": {
          "type": "string",
          "description": "The user's full name."
        },
        "age": {
          "type": "number",
          "description": "The user's age in years."
        },
        "gender": {
          "type": "string",
          "description": "The user's gender."
        },
        "email": {
          "type": "string",
          "description": "The user's email address.",
          "format": "email"
        },
        "whatsapp": {
          "type": "string",
          "description": "The user's WhatsApp number."
        }
      },
      "required": [
        "id",
        "userType",
        "name",
        "email"
      ]
    },
    "PhysicalAssessment": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "PhysicalAssessment",
      "type": "object",
      "description": "Represents a physical assessment record for a student.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the physical assessment."
        },
        "userId": {
          "type": "string",
          "description": "Reference to User."
        },
        "date": {
          "type": "string",
          "description": "The date of the physical assessment.",
          "format": "date-time"
        },
        "weight": {
          "type": "number",
          "description": "The user's weight in kilograms."
        },
        "height": {
          "type": "number",
          "description": "The user's height in centimeters."
        }
      },
      "required": [
        "id",
        "userId",
        "date"
      ]
    },
    "WorkoutSession": {
      "title": "WorkoutSession",
      "type": "object",
      "description": "Record of a training session completed by a student.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "pseSession": { "type": "number" },
        "pleasureScale": { "type": "number" },
        "duration": { "type": "number" }
      }
    },
    "Exercise": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Exercise",
      "type": "object",
      "description": "Represents a specific exercise performed or prescribed.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "sets": { "type": "number" },
        "reps": { "type": "string" },
        "weight": { "type": "number" },
        "pseExercise": { "type": "number" }
      },
      "required": [
        "id",
        "name"
      ]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "Stores user profile data."
        }
      },
      {
        "path": "/users/{userId}/physicalAssessments/{assessmentId}",
        "definition": {
          "entityName": "PhysicalAssessment",
          "schema": { "$ref": "#/backend/entities/PhysicalAssessment" },
          "description": "Physical assessments of a student."
        }
      },
      {
        "path": "/users/{userId}/trainingPrograms/{programId}/workoutSessions/{sessionId}",
        "definition": {
          "entityName": "WorkoutSession",
          "schema": { "$ref": "#/backend/entities/WorkoutSession" },
          "description": "History of workout sessions."
        }
      },
      {
        "path": "/users/{userId}/trainingPrograms/{programId}/workoutSessions/{sessionId}/exercises/{exerciseId}",
        "definition": {
          "entityName": "Exercise",
          "schema": { "$ref": "#/backend/entities/Exercise" },
          "description": "Individual exercises performed in a session."
        }
      },
      {
        "path": "/professors/{professorId}/students/{studentId}",
        "definition": {
          "entityName": "User",
          "description": "ACL mapping for professor-student relationship."
        }
      }
    ]
  }
}
