
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Perfil do usuário incluindo gênero para identificação visual.",
      "properties": {
        "id": { "type": "string" },
        "userType": { "type": "string", "enum": ["student", "professor"] },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoUrl": { "type": "string" },
        "age": { "type": "number" },
        "gender": { "type": "string", "enum": ["male", "female", "other"] },
        "whatsapp": { "type": "string" },
        "restrictions": { "type": "string" },
        "anamnesis": { "type": "string" },
        "goals": { "type": "string" }
      }
    },
    "PhysicalAssessment": {
      "title": "PhysicalAssessment",
      "type": "object",
      "description": "Avaliação completa: Antropometria, Metabólico e Neuromotor.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "weight": { "type": "number" },
        "height": { "type": "number" },
        "circumferences": {
          "type": "object",
          "properties": {
            "waist": { "type": "number" },
            "armR": { "type": "number" },
            "armL": { "type": "number" },
            "forearmR": { "type": "number" },
            "forearmL": { "type": "number" },
            "thighR": { "type": "number" },
            "thighL": { "type": "number" },
            "legR": { "type": "number" },
            "legL": { "type": "number" }
          }
        },
        "skinfolds": {
          "type": "object",
          "properties": {
            "subscapular": { "type": "number" },
            "triceps": { "type": "number" },
            "biceps": { "type": "number" },
            "midAxillary": { "type": "number" },
            "pectoral": { "type": "number" },
            "suprailiac": { "type": "number" },
            "abdominal": { "type": "number" },
            "thigh": { "type": "number" },
            "midLeg": { "type": "number" }
          }
        },
        "metabolic": {
          "type": "object",
          "properties": {
            "vo2max": { "type": "number" },
            "testNotes": { "type": "string" }
          }
        },
        "neuromotor": {
          "type": "object",
          "properties": {
            "tenRmTest": { "type": "number" },
            "oneRmEstimated": { "type": "number" },
            "sitToStand": { "type": "number" },
            "tug": { "type": "number" }
          }
        }
      }
    },
    "Notification": {
      "title": "Notification",
      "type": "object",
      "description": "Notificações internas para o usuário.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "Perfil" },
    "/users/{userId}/physicalAssessments/{id}": { "schema": "PhysicalAssessment", "description": "Avaliações" },
    "/users/{userId}/notifications/{id}": { "schema": "Notification", "description": "Notificações" }
  }
}
