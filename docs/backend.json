
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Perfil do usuário (Aluno ou Professor).",
      "properties": {
        "id": { "type": "string" },
        "userType": { "type": "string", "enum": ["student", "professor"] },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoUrl": { "type": "string", "description": "URL da foto de perfil do usuário." },
        "age": { "type": "number" },
        "gender": { "type": "string" },
        "whatsapp": { "type": "string" }
      }
    },
    "PhysicalAssessment": {
      "title": "PhysicalAssessment",
      "type": "object",
      "description": "Dados básicos da avaliação física.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "weight": { "type": "number" },
        "height": { "type": "number" }
      }
    },
    "WorkoutSession": {
      "title": "WorkoutSession",
      "type": "object",
      "description": "Registro de uma sessão de treino completa.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "pseSession": { "type": "number" },
        "pleasureScale": { "type": "number" },
        "duration": { "type": "number" }
      }
    },
    "ExerciseHistory": {
      "title": "ExerciseHistory",
      "type": "object",
      "description": "Registro individual de cada exercício feito no treino.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "sets": { "type": "number" },
        "reps": { "type": "string" },
        "weight": { "type": "number" },
        "pseExercise": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": { "entityName": "User", "description": "Perfil do usuário." }
      },
      {
        "path": "/users/{userId}/physicalAssessments/{assessmentId}",
        "definition": { "entityName": "PhysicalAssessment", "description": "Histórico de avaliações." }
      },
      {
        "path": "/users/{userId}/workoutHistory_flat/{sessionId}",
        "definition": { "entityName": "WorkoutSession", "description": "Sessões de treino (formato plano para dashboards)." }
      },
      {
        "path": "/users/{userId}/exerciseHistory_flat/{exerciseId}",
        "definition": { "entityName": "ExerciseHistory", "description": "Exercícios individuais (formato plano para análises)." }
      },
      {
        "path": "/professors/{professorId}/students/{studentId}",
        "definition": { "description": "ACL: Alunos vinculados a este professor." }
      }
    ]
  }
}
