
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Perfil do usuário (Aluno ou Professor).",
      "properties": {
        "id": { "type": "string" },
        "userType": { "type": "string", "enum": ["student", "professor"] },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoUrl": { "type": "string" },
        "age": { "type": "number" },
        "gender": { "type": "string" },
        "whatsapp": { "type": "string" },
        "restrictions": { "type": "string", "description": "Restrições médicas ou físicas preenchidas pelo aluno." },
        "anamnesis": { "type": "string", "description": "Histórico de saúde." },
        "goals": { "type": "string", "description": "Objetivos do aluno." }
      }
    },
    "AuthCode": {
      "title": "AuthCode",
      "type": "object",
      "description": "Tokens temporários para login via e-mail.",
      "properties": {
        "email": { "type": "string" },
        "code": { "type": "string" },
        "expiresAt": { "type": "string", "format": "date-time" }
      }
    },
    "PhysicalAssessment": {
      "title": "PhysicalAssessment",
      "type": "object",
      "description": "Avaliação física completa incluindo composição corporal e medidas bilaterais.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "weight": { "type": "number" },
        "height": { "type": "number" },
        "subescapular": { "type": "number" },
        "tricipital": { "type": "number" },
        "bicipital": { "type": "number" },
        "axilarMedia": { "type": "number" },
        "peitoral": { "type": "number" },
        "supraIliaca": { "type": "number" },
        "abdominal": { "type": "number" },
        "coxa": { "type": "number" },
        "pernaMedial": { "type": "number" },
        "bracoD": { "type": "number" },
        "bracoE": { "type": "number" },
        "antebracoD": { "type": "number" },
        "antebracoE": { "type": "number" },
        "coxaD": { "type": "number" },
        "coxaE": { "type": "number" },
        "pernaD": { "type": "number" },
        "pernaE": { "type": "number" },
        "cintura": { "type": "number" },
        "abdomen": { "type": "number" },
        "quadril": { "type": "number" },
        "vo2Max": { "type": "number" },
        "fatPercentage": { "type": "number" }
      }
    },
    "WorkoutSession": {
      "title": "WorkoutSession",
      "type": "object",
      "description": "Registro de uma sessão de treino com escalas de percepção.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "recoveryScale": { "type": "number", "description": "Escala Subjetiva de Recuperação (ESR) 1-10" },
        "pleasureScale": { "type": "number", "description": "Feeling Scale -5 a +5" },
        "pseSession": { "type": "number", "description": "Percepção Subjetiva de Esforço 1-10" },
        "duration": { "type": "number", "description": "Duração em minutos" },
        "internalLoad": { "type": "number", "description": "Carga Interna (PSE x Duração)" }
      }
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": { "entityName": "User", "description": "Perfil do usuário." }
      },
      {
        "path": "/auth_codes/{email}",
        "definition": { "entityName": "AuthCode", "description": "Tokens de segurança." }
      },
      {
        "path": "/users/{userId}/physicalAssessments/{assessmentId}",
        "definition": { "entityName": "PhysicalAssessment", "description": "Histórico de avaliações." }
      },
      {
        "path": "/users/{userId}/workoutHistory_flat/{sessionId}",
        "definition": { "entityName": "WorkoutSession", "description": "Sessões de treino para dashboards." }
      }
    ]
  }
}
